<Window x:Class="Khrameeva3.AppWimdows.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Khrameeva3.AppWimdows"
        mc:Ignorable="d"
        Title="МирИгрушек" Height="750" Width="1100" Loaded="Window_Loaded" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Background="{StaticResource backgroundColor}" >
            <Image Source="/Images/Icon.JPG" Margin="5"/>
            <TextBlock x:Name="TitleTB"  Text="ООО «МирИгрушек» " Margin="10,5,10,5" />
            <TextBlock x:Name="FioTB" Margin="10,5,10,5" />
            <Button HorizontalAlignment="Right" Margin="10,5,10,5" x:Name="OrdersBTN" Click="OrdersBTN_Click" Visibility="Hidden">Заказы</Button>
            <Button HorizontalAlignment="Right" Margin="10,5,10,5" x:Name="ExitBTN" Click="ExitBTN_Click">Выход</Button>

        </DockPanel>
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
