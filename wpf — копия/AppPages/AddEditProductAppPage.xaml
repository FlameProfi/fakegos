<Page x:Class="Khrameeva3.AppPages.AddEditProductAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Khrameeva3.AppPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditProductAppPage" Loaded="Page_Loaded">

    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <DockPanel LastChildFill="False" Visibility="Hidden" x:Name="IdDP">
                <TextBlock Text="Id:"/>
                <TextBlock Text="{Binding Id}" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Наименование товара:"/>
                <ComboBox x:Name="TypeCB" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Категория товара:"/>
                <ComboBox x:Name="CategoryCB" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Описание товара:"/>
                <TextBox Text="{Binding Description}" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Производитель:"/>
                <ComboBox x:Name="ManufacturerCB" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Поставщик:"/>
                <ComboBox x:Name="SupplierCB" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Цена:"/>
                <TextBox Text="{Binding Price}" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Единица измерения:"/>
                <ComboBox x:Name="UnitCB" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Количество на складе:"/>
                <TextBox Text="{Binding QuanityInStock}" MinWidth="100"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Действующая скидка:"/>
                <TextBox Text="{Binding Discount}" MinWidth="100"/>
                <TextBlock Text="%"/>
            </DockPanel>
            <Button x:Name="SaveBTN" Click="SaveBTN_Click">Сохранить</Button>
            <Button x:Name="BackBTN" Click="BackBTN_Click">Назад</Button>
            <Button x:Name="DeleteBTN" Click="DeleteBTN_Click" Visibility="Hidden" >Удалить</Button>
        </StackPanel>
    </Grid>
</Page>
