<Page x:Class="Khrameeva3.AppPages.AddEditOrderAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Khrameeva3.AppPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditOrderAppPage" Loaded="Page_Loaded">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Артикул:"/>
                <TextBox Text="{Binding TovarId}" MinWidth="200"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Статус заказа:" />
                <ComboBox x:Name="StatusCB"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Адрес пунта выдачи:"/>
                <ComboBox x:Name="AdressPVZCB"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Дата заказа:"/>
                <TextBox Text="{Binding DateOrder}" MinWidth="200"/>
            </DockPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="Дата выдачи:"/>
                <TextBox Text="{Binding DateDelivery}" MinWidth="200"/>
            </DockPanel>
            <Button x:Name="SaveBTN" Click="SaveBTN_Click">Сохранить</Button>
            <Button x:Name="BackBTN" Click="BackBTN_Click">Назад</Button>
            <Button x:Name="DeleteBTN" Click="DeleteBTN_Click" Visibility="Hidden">Удалить</Button>
        </StackPanel>
    </Grid>
</Page>
